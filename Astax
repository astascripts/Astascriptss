aguaBtn.MouseButton1Click:Connect(function()
    local waterParts = {}
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name:lower():find("water") or v.Name:lower():find("wave")) then
            table.insert(waterParts, v)
        end
    end
    local waveM = game.Workspace:FindFirstChild("WaveM")
    if waveM then table.insert(waterParts, waveM) end
    for _, part in ipairs(waterParts) do
        part:Destroy()
    end
    aguaBtn.BackgroundColor3 = Color3.new(0.7, 0.2, 0.2)
    aguaBtn.Text = "Água Removida"
    print("Água removida.")
end)

